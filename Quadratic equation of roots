import math
a=int(input("Enter a value" ))
b=int(input("Enter b value" ))
c=int(input("Enter c value" ))
d=(b*b)-(4*a*c)
if(d>0):
   root1=(-b+math.sqrt(d))/(2*a)
   root2=(-b-math.sqrt(d))/(2*a)
   print "roots= ",root1,",",root2
elif(d==0):
   r=-b/(2*a)
   print "root= ",r
else:
   r1=-b/(2*a)
   i1=math.sqrt(-d)/(2*a)
   print "Root1= ",r1,"+j",i1
   print "Root2= ",r1,"-j",i1
